rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /designs/{allPaths=**} {
      // Allow anyone to upload designs (needed for guest checkout)
      // and read them (needed for WhatsApp preview/Admin)
      allow read, write: if true;
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
